{
  "description": "Collect data while browsing social media platforms and upload it for analysis later",
  "manifest_version": 2,
  "name": "DS-Property-Percolator",
  "version": "0.1.0-alpha.1",
  "homepage_url": "https://github.com/virtualarchitectures/DS-Property-Percolator",

  "browser_specific_settings": {
    "gecko": {}
  },

  "icons": {
    "48": "images/ds-logo-48.png",
    "96": "images/ds-logo-96.png"
  },

  "browser_action": {
    "default_icon": "images/icon.png",
    "default_title": "DS-Property-Percolator"
  },

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "<all_urls>",
    "storage",
    "downloads",
    "activeTab",
    "tabs",
    "unlimitedStorage"
  ],

  "incognito": "not_allowed",

  "background": {
    "scripts": [
      "inc/dexie.js",
      "inc/he.js",
      "js/lib.js",
      "js/zs-background.js",
      "modules/daft.js",
      "modules/myhome.js",
      "modules/collegecribs.js",
      "modules/digs.js",
      "modules/hostingpower.js"
    ]
  }
}
